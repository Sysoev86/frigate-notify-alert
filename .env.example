# Optional environment for frigate-notify-alert.
# Copy to .env next to the service (it is gitignored) — systemd loads it if present.

# Error reporting to a Sentry-compatible server (e.g. self-hosted GlitchTip).
# Leave empty / unset to disable: the code then never touches the network.
GLITCHTIP_DSN=https://<key>@<your-glitchtip-host>/<project-id>

# Environment label shown on reported events (default: prod).
#GLITCHTIP_ENV=prod
